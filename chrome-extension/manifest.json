{
  "manifest_version": 3,
  "name": "ChatPulse",
  "version": "0.5.2",
  "version_name": "0.5.2 beta",
  "description": "Локально продолжает выбранные чаты ChatGPT в уже авторизованном профиле Chrome.",
  "minimum_chrome_version": "120",
  "permissions": [
    "alarms",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker-v2.js",
    "type": "module"
  },
  "action": {
    "default_title": "ChatPulse",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/logo.svg"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ]
}
